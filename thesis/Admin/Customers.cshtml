@model IEnumerable<AppleStoreWeb.Models.ApplicationUser>
@{
    ViewData["Title"] = "Khách hàng";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h5>Khách hàng (@Model.Count())</h5>
        <a href="@Url.Action("Index")" class="btn btn-outline-dark btn-sm">
            Quay lại
        </a>
    </div>

    @if (Model.Any())
    {
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead>
                        <tr>
                            <th>Tên</th>
                            <th>Email</th>
                            <th>SĐT</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>

                    @foreach (var user in Model)
                    {
                                <tr>

                                    <td>
                                        <div class="d-flex align-items-center">

                                            <div class="avatar me-2">
                                        @user.Name?.Substring(0, 1).ToUpper()
                                            </div>

                                            <div>
                                                <div>@user.Name</div>
                                                <div class="small text-muted">@user.UserName</div>
                                            </div>

                                        </div>
                                    </td>

                                    <td class="small">
                                @user.Email
                                    </td>

                                    <td class="small">
                                @(user.Phone ?? "-")
                                    </td>

                                    <td>
                                @if (user.Role == "admin")
                                {
                                                <span class="badge bg-dark">Admin</span>
                                }
                                else
                                {
                                                <span class="badge bg-secondary">User</span>
                                }
                                    </td>

                                    <td>
                                @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow)
                                {
                                                <span class="badge bg-danger">Khóa</span>
                                }
                                else
                                {
                                                <span class="badge bg-success">OK</span>
                                }
                                    </td>

                                    <td class="text-end">

                                @if (user.Role != "admin")
                                {
                                    @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow)
                                    {
                                                        <button class="btn btn-sm btn-outline-dark unlock-user-btn"
                                                                data-user-id="@user.Id">
                                                            Mở
                                                        </button>
                                    }
                                    else
                                    {
                                                        <button class="btn btn-sm btn-outline-dark lock-user-btn"
                                                                data-user-id="@user.Id">
                                                            Khóa
                                                        </button>
                                    }
                                }

                                    </td>

                                </tr>
                    }

                    </tbody>

                </table>

            </div>
    }
    else
    {
            <div class="text-center py-5 text-muted">
                Chưa có dữ liệu
            </div>
    }

</div>

<style>
.avatar {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    background: #111;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
}
</style>

@section Scripts {
    <script>
    $(function () {

        $('.lock-user-btn').click(function () {
            var id = $(this).data('user-id');

            if (confirm('Khóa tài khoản?')) {
                $.post('@Url.Action("LockUser")', { userId: id }, function (r) {
                    if (r.success) location.reload();
                });
            }
        });

        $('.unlock-user-btn').click(function () {
            var id = $(this).data('user-id');

            if (confirm('Mở khóa?')) {
                $.post('@Url.Action("UnlockUser")', { userId: id }, function (r) {
                    if (r.success) location.reload();
                });
            }
        });

    });
    </script>
}