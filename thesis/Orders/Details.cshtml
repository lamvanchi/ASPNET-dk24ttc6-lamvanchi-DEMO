@model AppleStoreWeb.Models.Order
@{
    ViewData["Title"] = "Đơn hàng";
}

<div class="container mt-4">

    <h5 class="mb-3">Đơn hàng #@Model.Id.Substring(0, 8)</h5>

    <div class="row">

        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-body">

                    @foreach (var item in Model.Items)
                    {
                            <div class="d-flex justify-content-between mb-2">

                                <div>
                                    <div>@item.Product?.Name</div>
                                    <div class="small text-muted">
                                    @item.StorageOption - @item.Color
                                    </div>
                                </div>

                                <div class="text-end small">
                                    <div>x @item.Quantity</div>
                                    <div class="fw-bold">
                                    @item.UnitPrice.ToString("N0") ₫
                                    </div>
                                </div>

                            </div>

                            <hr>
                    }

                    <div class="text-end">
                        <strong>Tổng: @Model.Total.ToString("N0") ₫</strong>
                    </div>

                </div>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm">
                <div class="card-body">

                    <div class="mb-2 small">
                        <strong>Mã:</strong> @Model.Id
                    </div>

                    <div class="mb-2 small">
                        <strong>Ngày:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>

                    <div class="mb-2 small">
                        <strong>Trạng thái:</strong>

                        @if (Model.Status == "pending")
                        {
                                <span class="badge bg-secondary">Chờ</span>
                        }
                        else if (Model.Status == "confirmed")
                        {
                                <span class="badge bg-primary">Đã xác nhận</span>
                        }
                        else if (Model.Status == "shipping")
                        {
                                <span class="badge bg-dark">Đang giao</span>
                        }
                        else if (Model.Status == "delivered")
                        {
                                <span class="badge bg-success">Hoàn tất</span>
                        }
                    </div>

                    <div class="mb-2 small">
                        <strong>Thanh toán:</strong> @Model.PaymentMethod
                    </div>

                    <div class="small">
                        <strong>Địa chỉ:</strong><br />
                        @Model.ShippingAddress
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>