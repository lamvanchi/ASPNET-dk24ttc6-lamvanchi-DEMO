@model IEnumerable<AppleStoreWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h3>Quản lý đơn hàng</h3>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Dashboard</a>
    </div>

    @if (Model.Any())
    {
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Khách</th>
                        <th>Ngày</th>
                        <th>Tổng</th>
                        <th>Trạng thái</th>
                        <th>Thanh toán</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var o in Model)
                {
                            <tr>
                                <td>@(o.Id.Length > 8 ? o.Id.Substring(0, 8) : o.Id)</td>
                                <td>@o.UserName</td>
                                <td>@o.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>@o.Total.ToString("N0") ₫</td>
                                <td>@o.Status</td>
                                <td>@o.PaymentMethod</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = o.Id })" class="btn btn-sm btn-primary">
                                        Xem
                                    </a>
                                </td>
                            </tr>
                }
                </tbody>
            </table>
    }
    else
    {
            <p>Không có đơn hàng</p>
    }

</div>