@model List<AppleStoreWeb.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model.Sum(c => c.Price * c.Quantity);
}

<div class="container mt-4">

    <h4 class="mb-3">
        <i class="fas fa-shopping-cart me-2"></i>Giỏ hàng
    </h4>

    @if (Model.Any())
    {
            <div class="row">

                <div class="col-lg-8">

                @foreach (var item in Model)
                {
                            <div class="card mb-3 shadow-sm">
                                <div class="row g-0">

                                    <div class="col-md-3 text-center p-2">
                                        <img src="@item.Image" class="img-fluid" style="max-height:120px; object-fit:contain;">
                                    </div>

                                    <div class="col-md-9">
                                        <div class="card-body py-2">

                                            <div class="d-flex justify-content-between">
                                                <div>
                                                    <h6 class="mb-1">@item.ProductName</h6>
                                                    <small class="text-muted">@item.ProductBrand</small>
                                                    <div class="small">Dung lượng: @item.StorageOption</div>
                                                    <div class="small">Màu: @item.Color</div>
                                                    <div class="fw-bold text-danger mt-1">
                                                @item.Price.ToString("N0") ₫
                                                    </div>
                                                </div>

                                                <div class="text-end">

                                                    <div class="input-group input-group-sm mb-2" style="width:110px;">
                                                        <button class="btn btn-outline-secondary quantity-btn"
                                                                data-action="decrease"
                                                                data-product-id="@item.ProductId"
                                                                data-storage-option="@item.StorageOption"
                                                                data-color="@item.Color">-</button>

                                                        <input type="number"
                                                               class="form-control text-center quantity-input"
                                                               value="@item.Quantity" min="1"
                                                               data-product-id="@item.ProductId"
                                                               data-storage-option="@item.StorageOption"
                                                               data-color="@item.Color">

                                                        <button class="btn btn-outline-secondary quantity-btn"
                                                                data-action="increase"
                                                                data-product-id="@item.ProductId"
                                                                data-storage-option="@item.StorageOption"
                                                                data-color="@item.Color">+</button>
                                                    </div>

                                                    <div class="small mb-2">
                                                        Tổng: <b>@((item.Price * item.Quantity).ToString("N0")) ₫</b>
                                                    </div>

                                                    <button class="btn btn-sm btn-outline-danger remove-item-btn"
                                                            data-product-id="@item.ProductId"
                                                            data-storage-option="@item.StorageOption"
                                                            data-color="@item.Color">
                                                        Xóa
                                                    </button>

                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                </div>
                            </div>
                }

                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm">
                        <div class="card-body">

                            <h6 class="mb-3">Đơn hàng</h6>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Tạm tính</span>
                                <span>@total.ToString("N0") ₫</span>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Vận chuyển</span>
                                <span class="text-success">Miễn phí</span>
                            </div>

                            <hr>

                            <div class="d-flex justify-content-between mb-3">
                                <strong>Tổng</strong>
                                <strong class="text-danger">@total.ToString("N0") ₫</strong>
                            </div>

                        @if (User.Identity!.IsAuthenticated)
                        {
                                    <a href="@Url.Action("Checkout", "Orders")" class="btn btn-dark w-100 mb-2">
                                        Thanh toán
                                    </a>
                        }
                        else
                        {
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-dark w-100 mb-2">
                                        Đăng nhập để thanh toán
                                    </a>
                        }

                            <a href="@Url.Action("Index", "Products")" class="btn btn-dark w-100">
                                Tiếp tục mua
                            </a>

                            <button class="btn btn-outline-danger w-100 mt-2" id="clear-cart-btn">
                                Xóa giỏ hàng
                            </button>

                        </div>
                    </div>
                </div>

            </div>
    }
    else
    {
            <div class="text-center py-5">
                <h5 class="text-muted">Giỏ hàng trống</h5>
                <a href="@Url.Action("Index", "Products")" class="btn btn-dark mt-3">
                    Mua sản phẩm
                </a>
            </div>
    }

</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $('.quantity-btn').click(function () {
                var action = $(this).data('action');
                var id = $(this).data('product-id');
                var storage = $(this).data('storage-option');
                var color = $(this).data('color');
                var input = $(this).siblings('.quantity-input');
                var qty = parseInt(input.val());

                qty = action === 'increase' ? qty + 1 : Math.max(1, qty - 1);
                input.val(qty);

                updateQuantity(id, storage, color, qty);
            });

            $('.quantity-input').change(function () {
                var id = $(this).data('product-id');
                var storage = $(this).data('storage-option');
                var color = $(this).data('color');
                var qty = Math.max(1, parseInt($(this).val()) || 1);

                $(this).val(qty);
                updateQuantity(id, storage, color, qty);
            });

            $('.remove-item-btn').click(function () {
                var id = $(this).data('product-id');
                var storage = $(this).data('storage-option');
                var color = $(this).data('color');

                if (confirm('Xóa sản phẩm này?')) {
                    removeFromCart(id, storage, color);
                }
            });

            $('#clear-cart-btn').click(function () {
                if (confirm('Xóa toàn bộ giỏ hàng?')) {
                    clearCart();
                }
            });
        });

        function updateQuantity(id, storage, color, qty) {
            $.post('@Url.Action("UpdateQuantity", "Cart")', {
                productId: id,
                storageOption: storage,
                color: color,
                quantity: qty
            }, function (res) {
                if (res.success) location.reload();
            });
        }

        function removeFromCart(id, storage, color) {
            $.post('@Url.Action("RemoveFromCart", "Cart")', {
                productId: id,
                storageOption: storage,
                color: color
            }, function (res) {
                if (res.success) location.reload();
            });
        }

        function clearCart() {
            $.post('@Url.Action("ClearCart", "Cart")', function (res) {
                if (res.success) location.reload();
            });
        }
    </script>
}