@model IEnumerable<AppleStoreWeb.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<!-- ================= BANNER SLIDER ================= -->
<div id="homeSlider" class="carousel slide mb-5" data-bs-ride="carousel">

    <!-- Indicators -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="2"></button>
    </div>

    <!-- Slides -->
    <div class="carousel-inner rounded shadow">

        <div class="carousel-item active">
            <img src="/images/banner1.jpg" class="d-block w-100" style="height:400px;object-fit:cover;" />
        </div>

        <div class="carousel-item">
            <img src="/images/banner2.jpg" class="d-block w-100" style="height:400px;object-fit:cover;" />
        </div>

        <div class="carousel-item">
            <img src="/images/banner3.jpg" class="d-block w-100" style="height:400px;object-fit:cover;" />
        </div>

    </div>

    <!-- Controls -->
    <button class="carousel-control-prev" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>

</div>
<!-- ================= END BANNER ================= -->


<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4">Sản phẩm nổi bật</h2>

        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var product in Model.Take(8))
                {
                    string[] images = Array.Empty<string>();

                    if (!string.IsNullOrEmpty(product.Images))
                    {
                        try
                        {
                            images = System.Text.Json.JsonSerializer
                            .Deserialize<string[]>(product.Images!)
                            ?? Array.Empty<string>();
                        }
                        catch
                        {
                            images = Array.Empty<string>();
                        }
                    }

                    var firstImage = images.FirstOrDefault() ?? "/images/no-image.png";

                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="card h-100 shadow-sm position-relative">

                            @if (product.OriginalPrice.HasValue
                           && product.OriginalPrice.Value > 0
                           && product.OriginalPrice.Value > product.Price)
                            {
                                var discount = (product.OriginalPrice.Value - product.Price)
                                / product.OriginalPrice.Value * 100;

                                <span class="badge bg-danger position-absolute m-2">
                                    -@discount.ToString("0")%
                                </span>
                            }

                            <img src="@firstImage"
                                 class="card-img-top p-3"
                                 style="height:200px;object-fit:contain"
                                 onerror="this.src='/images/no-image.png'" />

                            <div class="card-body d-flex flex-column">

                                <h6 class="card-title">
                                    @(product.Name ?? "Sản phẩm")
                                </h6>

                                <small class="text-white">
                                    @(product.Category ?? "")
                                </small>

                                <div class="mt-2 mb-2">
                                    ⭐ @string.Format("{0:0.0}", product.Rating)
                                    <span class="text-white">
                                        (@product.Reviews đánh giá)
                                    </span>
                                </div>

                                <div class="mt-auto">

                                    @if (product.OriginalPrice.HasValue
                                   && product.OriginalPrice.Value > product.Price)
                                    {
                                        <div class="text-white text-decoration-line-through">
                                            @string.Format("{0:N0}", product.OriginalPrice.Value) ₫
                                        </div>
                                    }

                                    <div class="fw-bold text-danger fs-5">
                                        @string.Format("{0:N0}", product.Price) ₫
                                    </div>
                                </div>

                                <div class="mt-3 d-flex gap-2">
                                    <a href="/Products/Details/@product.Id"
                                       class="btn btn-dark w-100">
                                        Xem
                                    </a>

                                    <button class="btn btn-primary w-100"
                                            onclick="addToCart('@product.Id')">
                                        Mua
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <h5>Không có sản phẩm</h5>
            </div>
        }
    </div>
</section>

<script>
    function addToCart(productId) {
        $.post('/Cart/AddToCart', { productId: productId, quantity: 1 })
            .done(function (data) {
                if (data && data.success) {
                    alert("Đã thêm vào giỏ hàng");

                    // 🔥 FIX QUAN TRỌNG: reload trang để update số lượng + UI
                    location.reload();
                } else {
                    alert("Thêm thất bại");
                }
            })
            .fail(function () {
                alert("Lỗi server");
            });
    }
</script>