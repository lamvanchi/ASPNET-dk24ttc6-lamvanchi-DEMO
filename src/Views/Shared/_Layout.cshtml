<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppleShop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppleStoreWeb.styles.css" asp-append-version="true" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-color: #6366f1;
            --secondary-color: #8b5cf6;
            --accent-color: #ec4899;
            --dark-bg: #0f172a;
            --card-bg: #1e293b;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
        }

        * {
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: var(--dark-bg);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* Navbar */
        .navbar {
            background: rgba(15, 23, 42, 0.95) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(99, 102, 241, 0.2);
            padding: 1rem 0;
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-link {
            color: var(--text-secondary) !important;
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            color: var(--text-primary) !important;
            background: rgba(99, 102, 241, 0.1);
        }

        .nav-link.active {
            color: var(--primary-color) !important;
        }
        /* FIX MENU KHÔNG XUỐNG DÒNG */
        .navbar-nav {
            flex-wrap: nowrap;
        }

            .navbar-nav .nav-link {
                white-space: nowrap;
            }

        /* FIX RIGHT SIDE KHÔNG ĐẨY BỂ LAYOUT */
        .navbar .d-flex {
            flex-wrap: nowrap;
        }

        /* GIẢM SEARCH CHO KHỎI CHIẾM CHỖ */
        .search-box {
            width: 180px;
        }

        /* TRÁNH USERNAME QUÁ DÀI */
        .dropdown-toggle {
            max-width: 140px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        /* Search */
        .search-box {
            background: var(--card-bg);
            border: 1px solid rgba(99, 102, 241, 0.3);
            border-radius: 25px;
            padding: 0.5rem 1rem;
            color: var(--text-primary);
            width: 250px;
        }

        .search-box:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }

        .search-box::placeholder {
            color: var(--text-secondary);
        }

        /* Buttons */
        .btn-glow {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            padding: 0.5rem 1.5rem;
            border-radius: 25px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-glow:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4);
            color: white;
        }

        .btn-outline-glow {
            background: transparent;
            border: 2px solid var(--primary-color);
            color: var(--text-primary);
            padding: 0.5rem 1.5rem;
            border-radius: 25px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-outline-glow:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-2px);
        }

        /* Cart Badge */
        .cart-badge {
            background: linear-gradient(135deg, var(--accent-color), #f97316);
            font-size: 11px;
            padding: 3px 8px;
        }

        /* Footer */
        footer {
            background: var(--card-bg);
            border-top: 1px solid rgba(99, 102, 241, 0.2);
            padding: 3rem 0 1.5rem;
            margin-top: 4rem;
        }

        footer h5 {
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        footer a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        footer a:hover {
            color: var(--primary-color);
        }

        footer p {
            color: var(--text-secondary);
        }

        /* Dropdown */
        .dropdown-menu {
            background: var(--card-bg);
            border: 1px solid rgba(99, 102, 241, 0.2);
            border-radius: 12px;
            padding: 0.5rem;
        }

        .dropdown-item {
            color: var(--text-secondary);
            border-radius: 8px;
            padding: 0.75rem 1rem;
        }

        .dropdown-item:hover {
            background: rgba(99, 102, 241, 0.1);
            color: var(--text-primary);
        }

        /* Container */
        .container {
            max-width: 1400px;
        }

        /* Animations */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-in {
            animation: fadeInUp 0.6s ease-out;
        }
        /* FIX DROPDOWN BỊ CHE */
        .navbar {
            position: relative;
            z-index: 1000;
        }

        .dropdown-menu {
            z-index: 9999 !important;
            position: absolute !important;
        }

        /* nếu bị che bởi container */
        .container, main {
            overflow: visible !important;
        }

       
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-bolt me-2"></i>AppleShop
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- MENU -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">
                                <i class="fas fa-shopping-bag me-1"></i>Sản phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">
                                <i class="fas fa-info-circle me-1"></i>Giới thiệu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">
                                <i class="fas fa-envelope me-1"></i>Liên hệ
                            </a>
                        </li>
                    </ul>

                    <!-- RIGHT SIDE -->
                    <div class="d-flex align-items-center">

                        <!-- SEARCH -->
                        <form class="d-flex me-3" asp-controller="Products" asp-action="Index" method="get">
                            <input class="search-box me-2" type="search" name="Search" placeholder="Tìm sản phẩm...">
                            <button class="btn btn-glow" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>

                        <!-- CART -->
                        <a class="btn btn-outline-glow me-2 position-relative" asp-controller="Cart" asp-action="Index">
                            <i class="fas fa-shopping-cart"></i>
                            <span id="cart-count"
                                  class="position-absolute top-0 start-100 translate-middle cart-badge rounded-pill">
                                0
                            </span>
                        </a>

                        <!-- USER -->
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-glow dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i> @User.Identity.Name
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Orders" asp-action="Index">
                                            <i class="fas fa-box me-2"></i>Đơn hàng
                                        </a>
                                    </li>

                                    @if (User.IsInRole("admin"))
                                    {
                                        <li><hr class="dropdown-divider" style="border-color: rgba(99,102,241,0.2);"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                                <i class="fas fa-cog me-2"></i>Quản trị
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider" style="border-color: rgba(99,102,241,0.2);"></li>

                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-glow me-2" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                            <a class="btn btn-glow" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        }

                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row">

                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-bolt me-2"></i>AppleShop</h5>
                    <p>Thế giới công nghệ trong tầm tay bạn. Chuyên cung cấp các sản phẩm công nghệ chính hãng với giá tốt nhất.</p>
                    <div class="mt-3">
                        <a href="#" class="me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-youtube fa-lg"></i></a>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <h5>Liên kết nhanh</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index"><i class="fas fa-chevron-right me-2" style="font-size: 10px;"></i>Trang chủ</a></li>
                        <li class="mb-2"><a asp-controller="Products" asp-action="Index"><i class="fas fa-chevron-right me-2" style="font-size: 10px;"></i>Sản phẩm</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="About"><i class="fas fa-chevron-right me-2" style="font-size: 10px;"></i>Về chúng tôi</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Contact"><i class="fas fa-chevron-right me-2" style="font-size: 10px;"></i>Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-md-4 mb-4">
                    <h5>Thông tin liên hệ</h5>
                    <p><i class="fas fa-map-marker-alt me-2"></i>123 Đường Công Nghệ, Quận 1, TP.HCM</p>
                    <p><i class="fas fa-phone me-2"></i>1900 xxxx</p>
                    <p><i class="fas fa-envelope me-2"></i>support@appleshop.vn</p>
                    <p><i class="fas fa-clock me-2"></i>8:00 - 22:00 (T2-CN)</p>
                </div>

            </div>

            <hr style="border-color: rgba(99,102,241,0.2);">

            <div class="row">
                <div class="col-md-6">
                    <p class="mb-0">&copy; 2026 AppleShop. Tất cả quyền được bảo lưu.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="#" class="me-3">Điều khoản</a>
                    <a href="#" class="me-3">Bảo mật</a>
                    <a href="#">Chính sách</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            updateCartCount();
        });

        function updateCartCount() {
            $.get('@Url.Action("GetCartCount", "Cart")', function (data) {
                if (data && data.count !== undefined) {
                    $('#cart-count').text(data.count);
                }
            }).fail(function () {
                console.log("Không load được cart count");
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>